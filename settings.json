{
  "permissions": {
    "defaultMode": "bypassPermissions"
  },
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node",
            "args": ["C:\\Users\\380kk\\.claude\\hooks\\session-start-reminders.mjs"],
            "timeout": 15
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node",
            "args": ["C:\\Users\\380kk\\.claude\\hooks\\stop-reminders.mjs"],
            "timeout": 15
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "node",
            "args": ["C:\\Users\\380kk\\.claude\\hooks\\style-audit.mjs"],
            "timeout": 200,
            "statusMessage": "文风审计中…"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "node",
            "args": ["C:\\Users\\380kk\\.claude\\hooks\\manyread-rebuild.mjs"],
            "timeout": 300,
            "async": true,
            "statusMessage": "重建 manyread 索引…"
          }
        ]
      }
    ]
